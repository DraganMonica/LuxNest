@{
    ViewData["Title"] = "My Bookings";
}

<div class="w-100 card border-0 p-4">
    <div class="card-header bg-success bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">My Bookings</h2>
            </div>
        </div>
    </div>
    <div class="card-body border p-4">
        <table id="tblMyBookings" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Villa</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Nights</th>
                    <th>Guests</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Cancel Confirmation Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: 1px solid #555;">
            <div class="modal-header border-0">
                <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Cancel Booking</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <p class="mb-1">Are you sure you want to cancel this booking?</p>
                <p id="refundMessage" class="fw-bold mt-2 mb-0"></p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-3">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Keep Booking</button>
                <a id="confirmCancelBtn" href="#" class="btn btn-danger px-4">Yes, Cancel</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/myBookings.js"></script>
    <script>
        function showCancelModal(bookingId, refundLabel, refundClass) {
            document.getElementById('refundMessage').innerHTML = `<span class="${refundClass}">${refundLabel}</span>`;
            document.getElementById('confirmCancelBtn').href = `/booking/CancelBookingUser?bookingId=${bookingId}`;
            new bootstrap.Modal(document.getElementById('cancelModal')).show();
        }
    </script>
}
