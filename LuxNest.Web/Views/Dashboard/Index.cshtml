<div class="container-fluid">
    <div class="row">
        <div class="page-title-box d-flex align-items-center justify-content-between">
            <h4 class="mb-0">Dashboard</h4>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 col-xl-4 mt-2">
            <div class="card">
                <div class="card-body">
                    <div class="float-end mt-2">
                        <div id="totalBookingsRadialChart" data-colors='["--bs-success"]'></div>
                    </div>
                    <div>
                        <p class="text-muted mb-0" style="font-size:16px;">Total Bookings for this month</p>
                        <h2 class="my-1" style="font-size:42px; font-weight:700;">
                            <span id="spanTotalBookingCount">XXX</span>
                        </h2>
                    </div>
                    <p class="text-muted mt-3 mb-0" style="font-size:14px;" id="sectionBookingCount"></p>
                    <div class="justify-content-center text-center chart-spinner" style="display:none">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4 mt-2">
            <div class="card">
                <div class="card-body">
                    <div class="float-end mt-2">
                        <div id="totalUserRadialChart" data-colors='["--bs-warning"]'></div>
                    </div>
                    <div>
                        <p class="text-muted mb-0" style="font-size:16px;">Total Users for this month</p>
                        <h2 class="my-1" style="font-size:42px; font-weight:700;">
                            <span id="spanTotalUserCount">XXX</span>
                        </h2>
                    </div>
                    <p class="text-muted mt-3 mb-0" style="font-size:14px;" id="sectionUserCount"></p>
                    <div class="justify-content-center text-center chart-spinner" style="display:none">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4 mt-2">
            <div class="card">
                <div class="card-body">
                    <div class="float-end mt-2">
                        <div id="totalRevenueRadialChart" data-colors='["#F0006B"]'></div>
                    </div>
                    <div>
                        <p class="text-muted mb-0" style="font-size:16px;">Total Revenue for this month</p>
                        <h2 class="my-1" style="font-size:42px; font-weight:700;">
                            <span id="spanTotalRevenueCount">XXX</span>
                        </h2>
                    </div>
                    <p class="text-muted mt-3 mb-0" style="font-size:14px;" id="sectionRevenueCount"></p>
                    <div class="justify-content-center text-center chart-spinner" style="display:none">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-12 col-xl-6 mt-2">
            <div class="card">
                <div class="card-body">
                    <div class="">
                        <p class="text-muted mb-0">Booking Status Distribution</p>
                    </div>
                    <div id="customerBookingsPieChart" data-colors='["--bs-success","--bs-primary","--bs-info","--bs-danger","--bs-warning"]'>
                    </div>
                    <div class="justify-content-center text-center chart-spinner" style="display:none">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-12 mt-2">
            <div class="card">
                <div class="card-body">
                    <p class="text-muted mb-0" style="font-size:15px;">New Bookings — Current Month</p>
                    <div id="bookingsLineChart" style="min-height:320px;"></div>
                    <div class="justify-content-center text-center chart-spinner" style="display:none">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-12 mt-2">
            <div class="card">
                <div class="card-body">
                    <p class="text-muted mb-0" style="font-size:15px;">New Customers — Current Month</p>
                    <div id="customersLineChart" style="min-height:320px;"></div>
                    <div class="justify-content-center text-center chart-spinner" style="display:none">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/js/dashboard/radialChart.js"></script>
    <script src="~/js/dashboard/getTotalBookingsRadial.js"></script>
    <script src="~/js/dashboard/getTotalRevenueRadial.js"></script>
    <script src="~/js/dashboard/getTotalUserRadial.js"></script>
    <script src="~/js/dashboard/getCustomerBookingPieChart.js"></script>
    <script src="~/js/dashboard/getCustomerAndBookingLineChart.js"></script>

}
